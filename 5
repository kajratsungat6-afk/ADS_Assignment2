#include <iostream>
#include <unordered_map>
#include <string>
using namespace std;

int lengthOfLongest(string s) {
    unordered_map<char, int> last; 
    int left = 0, maxLen = 0;

    for (int right = 0; right < s.size(); right++) {
        if (last.count(s[right]) && last[s[right]] >= left)
            left = last[s[right]] + 1;
        last[s[right]] = right;
        maxLen = max(maxLen, right - left + 1);
    }
    return maxLen;
}

int main() {
    cout << lengthOfLongest("abcabcbb") << "\n"; 
    cout << lengthOfLongest("pwwkew")   << "\n"; 
}
